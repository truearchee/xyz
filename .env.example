# Copy this file to .env and fill in real values for local development.
# Never commit the .env file to version control.
# This file documents Stage 1 variables and known placeholders for later stages.
# New variables will be added to this file as each stage introduces them.

# ─── Database ───────────────────────────────────────────────────────────────
# These three variables are used by the Postgres container on first boot.
POSTGRES_DB=xyz_lms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Full async connection URL — used by the backend and Alembic.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/xyz_lms

# Isolated async test database URL — used by destructive migration tests only.
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/xyz_lms_test

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Supabase Auth (values provided at Stage 2) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# ─── Object Storage ────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=section-assets
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1
MAX_SECTION_ASSET_UPLOAD_BYTES=26214400
MAX_TRANSCRIPT_UPLOAD_BYTES=10485760
SIGNED_READ_URL_TTL_SECONDS=300

# ─── LLM Provider (values provided at Stage 4) ──────────────────────────────
LLM_PROVIDER_BASE_URL=https://api.k2think.ai
LLM_API_KEY=your-llm-api-key-here

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development
