# Copy this file to .env and fill in real values for local development.
# Never commit the .env file to version control.
# This file documents Stage 1 variables and known placeholders for later stages.
# New variables will be added to this file as each stage introduces them.

# ─── Database ───────────────────────────────────────────────────────────────
# These three variables are used by the Postgres container on first boot.
POSTGRES_DB=xyz_lms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Full async connection URL — used by the backend and Alembic.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/xyz_lms

# Isolated async test database URL — used by destructive migration tests only.
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/xyz_lms_test

# Comma-separated list of browser origins allowed to call the backend.
# No trailing slashes. Add staging/production URLs when deploying.
CORS_ORIGINS=http://localhost:3000

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Supabase Auth (values provided at Stage 2) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLIC_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# ─── Object Storage ────────────────────────────────────────────────────────
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=section-assets
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1
MAX_SECTION_ASSET_UPLOAD_BYTES=26214400
MAX_TRANSCRIPT_UPLOAD_BYTES=10485760
SIGNED_READ_URL_TTL_SECONDS=300

# ─── Transcript Embeddings ─────────────────────────────────────────────────
EMBEDDING_MODEL_PATH=/opt/models/sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_REVISION=1110a243fdf4706b3f48f1d95db1a4f5529b4d41
EMBEDDING_BATCH_SIZE=16
EMBEDDING_WORKER_CONCURRENCY=1
EMBEDDING_DEVICE=cpu

# ─── LLM Provider + capacity (Stage 4.5) ────────────────────────────────────
# Provider mode: 'deterministic' (CI/local default, no network) or 'k2think' (real, Stage 4.5b).
LLM_PROVIDER=deterministic
LLM_PROVIDER_BASE_URL=https://api.k2think.ai
# Required only when LLM_PROVIDER=k2think (verified end-to-end at gate 2.B). Unused in 4.5a.
LLM_API_KEY=your-llm-api-key-here
# Model identifiers (exact deployment aliases confirmed at IFM onboarding — rule 11).
LLM_BRIEF_MODEL_ID=MBZUAI-IFM/K2-V2-Instruct
LLM_DETAILED_MODEL_ID=MBZUAI-IFM/K2-Think-v0
# Context windows (tokens) used for route selection / over-context detection.
LLM_CEREBRAS_CONTEXT_WINDOW_TOKENS=32768
LLM_NVIDIA_CONTEXT_WINDOW_TOKENS=131072
# Redis limiter budgets per backend (rule 15).
LLM_CEREBRAS_RPM=20
LLM_CEREBRAS_TPM=100000
LLM_CEREBRAS_CONCURRENCY=10
LLM_NVIDIA_RPM=10
LLM_NVIDIA_TPM=105000
LLM_NVIDIA_CONCURRENCY=10
# Background jobs may consume at most (100 - headroom)% of each dimension; the rest is reserved
# for INTERACTIVE traffic (Stage 8).
LLM_INTERACTIVE_HEADROOM_PERCENT=20
# Concurrency-lease TTL (seconds); a crashed worker's slot becomes reclaimable after this.
LLM_LEASE_TTL_SECONDS=120

# ─── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Leave unset/false outside E2E. When true, exposes browser-only Playwright hooks.
NEXT_PUBLIC_E2E_TEST_HOOKS=false

# ─── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development
