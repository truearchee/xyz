# Stage 4.8 — staging environment matrix (B8). SECRETS REDACTED. Variable names follow the umbrella
# spec Filing note (code wins). On Fly: non-secret values live in fly.toml [env]; secrets go via
# `fly secrets set`. This file documents the full set and is the input to `scripts/check-staging-env`
# (copy to .env.staging, fill real values, then: set -a; . ./.env.staging; set +a; sh scripts/check-staging-env).

# ── Runtime environment (drives the §8 hygiene gates) ──
ENVIRONMENT=staging

# ── Database: dual URL (adr-041). App + workers use the transaction POOLER; Alembic + the reaper
#    advisory lock use the DIRECT/session endpoint. The two MUST differ. ──
# App (pooler): prepared statements off — DATABASE_POOLER=true drives that explicitly (NOT a port sniff).
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?ssl=require
# Alembic / advisory lock (direct/session): full prepared-statement support.
DIRECT_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_POOLER=true
# Optional pool sizing (defaults: size=5, overflow=0). Keep small — connection budget (§7.B).
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=0

# ── Redis (protocol, persistent blocking pops; configure noeviction on the instance — §7.C) ──
REDIS_URL=rediss://default:<password>@<host>:<port>

# ── Supabase (STAGING project; per-project JWKS + issuer; ECC P-256 / ES256 already supported) ──
SUPABASE_URL=https://<staging-ref>.supabase.co
SUPABASE_SECRET_KEY=<staging service-role key — BACKEND ONLY, never NEXT_PUBLIC_>
SUPABASE_JWKS_URL=https://<staging-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<staging-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_STORAGE_BUCKET=<staging bucket>
# Optional: dev-project values so check-staging-env can assert staging != dev.
# DEV_SUPABASE_URL=https://<dev-ref>.supabase.co
# DEV_SUPABASE_JWKS_URL=https://<dev-ref>.supabase.co/auth/v1/.well-known/jwks.json

# ── LLM provider (real K2Think; separate STAGING key so the per-deployment limiter doesn't contend
#    with local over the per-key quota — §7.J) ──
LLM_PROVIDER=k2think
LLM_API_KEY=<staging K2Think/IFM key — BACKEND ONLY>
LLM_PROVIDER_BASE_URL=https://api.k2think.ai
# LLM_BRIEF_MODEL_ID / LLM_DETAILED_MODEL_ID default to MBZUAI-IFM/K2-Think-v2 (ADR-025).

# ── CORS (D1): the staging FRONTEND origin (this is the frontend Fly app hostname) ──
CORS_ORIGINS=https://xyz-lms-frontend-staging.fly.dev
# Hint for check-staging-env's membership assertion:
STAGING_FRONTEND_ORIGIN=https://xyz-lms-frontend-staging.fly.dev

# ── Embeddings (baked into the image; offline check at boot) ──
EMBEDDING_MODEL_REVISION=1110a243fdf4706b3f48f1d95db1a4f5529b4d41

# ── Frontend build-time (inlined into the bundle at `next build`; passed as Docker build args, NOT
#    runtime env). NEXT_PUBLIC_E2E_TEST_HOOKS is intentionally ABSENT (§8). ──
NEXT_PUBLIC_API_BASE_URL=https://xyz-lms-backend-staging.fly.dev
NEXT_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging anon key — public, browser-shipped>

# ── Identity bootstrap (4.8b; release phase, idempotent). ADMIN runs wherever its vars are set; the
#    known-credential LECTURER/STUDENT seeds require BOOTSTRAP_SEED_IDENTITIES=true AND not production.
#    Passwords are SECRETS (fly secrets set); emails/names may be non-secret. Never rotated on re-run. ──
BOOTSTRAP_SEED_IDENTITIES=true
BOOTSTRAP_ADMIN_EMAIL=admin@staging.example
BOOTSTRAP_ADMIN_PASSWORD=<admin password — SECRET>
BOOTSTRAP_ADMIN_NAME=Staging Admin
BOOTSTRAP_LECTURER_EMAIL=lecturer@staging.example
BOOTSTRAP_LECTURER_PASSWORD=<lecturer password — SECRET; E2E allowlisted>
BOOTSTRAP_LECTURER_NAME=Staging Lecturer
BOOTSTRAP_STUDENT_EMAIL=student@staging.example
BOOTSTRAP_STUDENT_PASSWORD=<student password — SECRET; E2E allowlisted>
BOOTSTRAP_STUDENT_NAME=Staging Student

# ── Connection budget (MF3; see deploy/staging-runbook.md for the table). Small pools so api + 3
#    workers + migrator + reaper stay under the plan's max_connections. ──
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=0

# ── MUST REMAIN ABSENT in staging (check-staging-env fails if any are set) ──
# NEXT_PUBLIC_E2E_TEST_HOOKS
# PIPELINE_FAULT_INJECTION_ENABLED / PIPELINE_FAULT_INJECTION / LLM_FAULT_INJECTION
# ENABLE_INTERNAL_SSE_PROBE   (4.8c; gated/absent in the prod build)
# Stale/renamed names (script rejects them): K2THINK_API_KEY, K2THINK_BASE_URL, APP_ENV,
#   SUPABASE_SERVICE_ROLE_KEY, EMBEDDING_MODEL_SHA, NEXT_PUBLIC_API_URL
