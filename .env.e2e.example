NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_E2E_TEST_HOOKS=true
E2E_SUPABASE_ALLOWED_URL=
E2E_TEST_PASSWORD=

# Embeddings for E2E: leave EMBEDDING_PROVIDER unset → the baked real MiniLM snapshot
# (sentence_transformers). It is deterministic for identical text (distance 0 → the 8.2 grounding gate
# still grounds on a verbatim chunk) AND keeps the pipeline-timing realism the Stage 4 transcript specs
# assume (deterministic embeddings complete so fast the transcript races past the intermediate
# 'chunked' projection state, breaking 4.3.5e's wait — see findings-8.2-gate-image-contention). The
# deterministic encoder is used by BACKEND PYTEST only (tests/conftest.py), not the live E2E stack.

# Backend runtime values for Dockerized E2E runs.
# For local Supabase, the browser URL remains 127.0.0.1/localhost, while
# Docker containers should use host.docker.internal for reachable Supabase APIs.
SUPABASE_URL=
SUPABASE_PUBLIC_URL=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
SUPABASE_STORAGE_BUCKET=section-assets
